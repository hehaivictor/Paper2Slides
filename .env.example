# Core LLM config
RAG_LLM_API_KEY=your_llm_api_key
RAG_LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Image generation config
IMAGE_GEN_PROVIDER=openrouter
IMAGE_GEN_API_KEY=your_image_api_key
IMAGE_GEN_BASE_URL=https://openrouter.ai/api/v1
IMAGE_GEN_MODEL=google/gemini-3-pro-image-preview
IMAGE_GEN_RESPONSE_MIME_TYPE=text/plain
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Parser / runtime config
PARSER=mineru
PARSE_METHOD=auto
MAX_CONCURRENT_FILES=1
VERBOSE=false
OUTPUT_LANGUAGE=zh-CN
PAPER2SLIDES_PROFILE=consulting_exec_cn
# Built-in consulting slide profile for general -> slides is enabled by default.
# Set to true/1 if you want to disable the fixed consulting prompt and fall back to the vanilla planner.
PAPER2SLIDES_DISABLE_DEFAULT_GENERAL_SLIDES_PROFILE=false
PAPER2SLIDES_DISABLE_DEFAULT_GENERAL_SLIDES_VISUAL_PROFILE=false
# Optional: override the built-in planning prompt with inline text or a file path.
PAPER2SLIDES_PLANNING_INSTRUCTION=
PAPER2SLIDES_PLANNING_INSTRUCTION_FILE=
# Optional: override the built-in visual style prompt with inline text or a file path.
PAPER2SLIDES_VISUAL_STYLE_INSTRUCTION=
PAPER2SLIDES_VISUAL_STYLE_INSTRUCTION_FILE=

# External service config
# Set this in cloud deployments to protect /api/v1/* endpoints.
API_AUTH_TOKEN=
# Optional public origin used to return absolute artifact URLs, e.g. https://paper.example.com
PUBLIC_BASE_URL=
